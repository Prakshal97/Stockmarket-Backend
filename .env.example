# ========================
# REQUIRED - Fill these in
# ========================

# Groq API Key (replaces Gemini)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# MongoDB Atlas Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=mongodb+srv://prakshaljain927_db_user:G9Ji3yDCoC0xnCO5@stockmarketagent.alybvnj.mongodb.net/?appName=stockmarketagent

# ========================
# OPTIONAL - Defaults work
# ========================

# Database name
DB_NAME=stockmarketagent

# How often to fetch new announcements (minutes)
FETCH_INTERVAL_MINUTES=10

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# NSE user agent header to avoid blocks
NSE_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# Max announcements to process per fetch cycle (to control Groq API usage)
MAX_PROCESS_PER_CYCLE=20
